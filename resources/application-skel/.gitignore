# All runtime security material lives in /certs/: TLS host.cert + host.key
# (PF-69), and the populated .env with real secrets (PF-71). Never commit any
# of those. The committed exception is .env.example — a template documenting
# which env vars the app needs, with placeholder values only.
/certs/*
!/certs/.env.example

# Play artifacts
/tmp/
/logs/
/test-result/
/precompiled/
/db/
/lib/
/modules/
*.iml
.idea/
.vscode/
